SECRET_KEY=replace-this-with-a-long-random-secret

# 主 AI 通道
AI_PRIMARY_NAME=OpenAI
AI_PRIMARY_KEY=
AI_PRIMARY_BASE_URL=https://api.openai.com/v1
AI_PRIMARY_MODEL=gpt-4.1-mini

# 备用 AI 通道（可选）
AI_BACKUP_NAME=
AI_BACKUP_KEY=
AI_BACKUP_BASE_URL=
AI_BACKUP_MODEL=

# 启动时初始化管理员（可选）
BOOTSTRAP_ON_STARTUP=1
INIT_ADMIN_USERNAME=
INIT_ADMIN_PASSWORD=
INIT_ADMIN_INVITE_CODE=

# 实验/聊天相关阈值
MIN_USER_MESSAGE_LENGTH=10
ROUND_RESET_INTERVAL_MINUTES=60
MIN_ROUNDS_FOR_CHECKIN=10
CHECKIN_COOLDOWN_HOURS=4
MIN_WEEKLY_CHECKINS_FOR_SURVEY=2

# CORS
# 显式允许的跨域来源，逗号分隔；生产环境建议写你的前端域名
CORS_ALLOW_ORIGINS=https://chat.example.com,https://admin.example.com

# 本地开发默认允许 localhost / 127.0.0.1 任意端口
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
